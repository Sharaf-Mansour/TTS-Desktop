{
  "name": "tts-desktop",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Electrobun desktop TTS app using hosted Microsoft Edge voices",
  "scripts": {
    "dev": "electrobun dev",
    "start": "electrobun dev",
    "build": "electrobun build",
    "build:stable": "electrobun build --env stable",
    "build:release": "electrobun build --release",
    "build:canary": "electrobun build --env canary"
  },
  "dependencies": {
    "edge-tts": "^1.0.1",
    "electrobun": "1.16.0",
    "node-edge-tts": "^1.2.10"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "rcedit": "^5.0.2",
    "typescript": "6.0.2"
  }
}
